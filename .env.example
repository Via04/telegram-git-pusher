# Telegram Bot API Token from @BotFather
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ

# Allowed Telegram Usernames or IDs (comma-separated for security)
# ALLOWED_USERS=your_telegram_username,123456789

# Base directory on server to store temporary repository clones
WORK_DIR=./tmp_repos

# Path to SQLite database file for persistent user sessions
DB_PATH=./bot.db

# Optional default SSH private key path on server for private repositories
# DEFAULT_SSH_KEY_PATH=/root/.ssh/id_rsa

# Default Git Author Info
DEFAULT_GIT_NAME=Telegram Bot Pusher
DEFAULT_GIT_EMAIL=bot@telegram.local

# Dry run mode (true = commit locally, do not push to remote)
DRY_RUN=false
